# Used by ./render-deployment-vars.sh (envsubst). 
# Iyes dendeni - 03/22/2026
#
# To streamline the deployment and ensure portability across environments, we utilize global variables. 
# Because Kubernetes Application objects do not natively support variables, fields like repoURL 
# must be static text unless the YAML is pre-rendered.
#
# Instructions:
#
# 1. Update your environment variables below.
#
# 2. Execute render-deployment-vars.sh to apply them
#
# 3. Commit the resulting YAML for Argo CD
#
#

# GitHub Repo URL where you will maintain deployment manifest file
# Important Note: 
# The Broadcom GitHub Repo github.gwd.broadcom.net is not resolvable from inside the cluster, so 
# ArgoCD will not be able to reach it and fetch the deployment manifest files.
# Please use your own private Git Repo.
export GIT_REPO_URL='https://github.gwd.broadcom.net/ESD/idsp-argocd-id604771.git'

# Public DNS suffix for ingress hostnames (e.g. kibana.<IDSP_PUBLIC_DOMAIN>).
export IDSP_PUBLIC_DOMAIN='id-broadcom.com'

# Static external IP for the ingress-nginx controller Service (GKE loadBalancerIP).
export INGRESS_LOAD_BALANCER_IP='34.19.89.223'

# Broadcom SSP Helm chart index (cadirectory, ssp, ssp-infra, sample-app).
export SSP_HELM_REPO_URL='https://ssp-helm-charts-staging.storage.googleapis.com'

# Chart version for SSP Helm applications (Helm targetRevision).
export CHART_VERSION='4.0.0-1144.stage'

# Secret names in namespace ssp: docker-registry pull for private images, TLS for SSP-related Ingress.
export SSP_REGISTRY_PULL_SECRET_NAME='ssp-registrypullsecret'
export SSP_GENERAL_TLS_SECRET_NAME='ssp-general-tls'
